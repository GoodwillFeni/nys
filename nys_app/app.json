{
  "expo": {
    "name": "NYS",
    "slug": "nys_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpg",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#27253f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nys.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "This app uses Bluetooth to configure NYS devices.",
        "NSBluetoothPeripheralUsageDescription": "This app uses Bluetooth to configure NYS devices."
      }
    },
    "android": {
      "package": "com.nys.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpg",
        "backgroundColor": "#27253f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/logo.jpg"
    },
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "neverForLocation": false
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "apiBaseUrl": "http://192.168.101.153:8000/api"
    }
  }
}
