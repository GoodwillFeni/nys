# =============================================================================
# Production .env template for nkunziyenungu.co.za (shared cPanel hosting)
# Copy this file to .env on the server (NOT into the repo). Fill in every
# placeholder marked CHANGE_ME before going live.
# =============================================================================

APP_NAME="Nkunziyenungu Systems"
APP_ENV=production
APP_KEY=                           # CHANGE_ME — run `php artisan key:generate --show` locally and paste the base64:... value
APP_DEBUG=false
APP_URL=https://nkunziyenungu.co.za
APP_TIMEZONE=Africa/Johannesburg

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Logs: daily rotation keeps shared-hosting disk under control
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---- Database (cPanel → MySQL Databases) ----
# cPanel prefixes DB and user names with your cPanel username, e.g. abcd1234_nys
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=CHANGE_ME_nys           # CHANGE_ME — full prefixed DB name from cPanel
DB_USERNAME=CHANGE_ME_nys           # CHANGE_ME — full prefixed user name from cPanel
DB_PASSWORD=CHANGE_ME               # CHANGE_ME — strong password set in cPanel

# ---- Sessions / Cache / Queue: all DB-backed (no Redis/Memcached on shared) ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.nkunziyenungu.co.za
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---- Frontend / Sanctum ----
FRONTEND_URL=https://nkunziyenungu.co.za
SANCTUM_STATEFUL_DOMAINS=nkunziyenungu.co.za,www.nkunziyenungu.co.za

# Trust the cPanel reverse proxy (Apache fronts the request → trust X-Forwarded-Proto for https detection)
TRUSTED_PROXIES=*

# ---- Mail (existing Gmail SMTP — same as dev) ----
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=nkunziyenungu@gmail.com
MAIL_PASSWORD=CHANGE_ME             # CHANGE_ME — Gmail App Password (16-char), do NOT commit
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=nkunziyenungu@gmail.com
MAIL_FROM_NAME="Nkunziyenungu Systems"

# ---- Unused on shared hosting; leave blank ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
